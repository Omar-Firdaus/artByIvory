# Copy to .env for local runs — https://developer.squareup.com/apps
#
# === GOING LIVE (production) ===
# 1) Square Dashboard: switch to Production (toggle), open your application.
# 2) Copy PRODUCTION Application ID, a PRODUCTION location ID, and a PRODUCTION access token.
# 3) Set below: SQUARE_ENV=production and the three values (must all be from the same production app).
# 4) Render → Environment: same variables; Save → redeploy.
# 5) Apple Pay: under this PRODUCTION application, register your storefront domain again if Square
#    requires it separately from sandbox (check Developer Dashboard → Apple Pay).
# 6) Optional: STRICT_CORS=true and CLIENT_ORIGIN=https://your-store.com,https://artbyivory.vercel.app

SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=

# Use "production" for real charges. Use "sandbox" only for Square test cards / test mode.
SQUARE_ENV=production

# Comma-separated allowed origins for your storefront (no trailing slashes on URLs).
CLIENT_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,https://artbyivory.vercel.app

# STRICT_CORS=true → only CLIENT_ORIGIN + localhost may call the API (recommended for production API).
# If unset/false, other origins are allowed (easier setup; less strict).
STRICT_CORS=true

# Local dev only. On Render, PORT is set automatically — do not set PORT in Render.
PORT=3001

# --- Render (Web Service → Environment) ---
# Set SQUARE_ENV=production and production SQUARE_* values. Omit PORT.
# After going live, keep STRICT_CORS=true and list every storefront origin in CLIENT_ORIGIN.
