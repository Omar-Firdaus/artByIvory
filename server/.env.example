# Copy to .env — https://developer.squareup.com/apps

SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_ENV=sandbox

# Your shop’s public URL(s) when deployed (comma-separated). Local http://localhost:ANY is auto-allowed.
# Include your live site, e.g. https://artbyivory.vercel.app
CLIENT_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,https://artbyivory.vercel.app

# Set STRICT_CORS=true when the API is public on the internet (only CLIENT_ORIGIN + localhost allowed).
STRICT_CORS=

# Local dev only. On Render, PORT is set for you — do not override in the Render dashboard.
PORT=3001

# --- Render (Web Service → Environment) ---
# Add the same vars as above (SQUARE_*, CLIENT_ORIGIN, STRICT_CORS). Omit PORT.
# CLIENT_ORIGIN must include https://artbyivory.vercel.app (and any preview URLs you use).
# Recommended for a public API: STRICT_CORS=true
