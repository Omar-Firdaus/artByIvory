# Copy to .env — https://developer.squareup.com/apps

SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_ENV=sandbox

# Your shop’s public URL(s) when deployed (comma-separated). Local http://localhost:ANY is auto-allowed.
CLIENT_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# Set STRICT_CORS=true when the API is public on the internet (only CLIENT_ORIGIN + localhost allowed).
STRICT_CORS=
PORT=3001
